#!/bin/sh
# RWANG write gate — pre-commit hook
# Rejects commits that modify a registered file without updating its RWANG sidecar.
# Installed by rwang-init; see RWANG-VERSION.md §7.

[ -d .rwang/meta ] || exit 0

hash_stdin() {
  if command -v sha256sum >/dev/null 2>&1; then sha256sum | cut -d' ' -f1
  else shasum -a 256 | cut -d' ' -f1
  fi
}

staged=$(git diff --cached --name-only --diff-filter=ACMR)
fail=0

for f in $staged; do
  case "$f" in .rwang/*) continue ;; esac
  meta=".rwang/meta/$f.json"
  [ -f "$meta" ] || continue   # not registered -> not gated

  if ! printf '%s\n' "$staged" | grep -qxF "$meta"; then
    echo "RWANG gate: '$f' is registered but its sidecar was not updated in this commit." >&2
    echo "            Run: RWANG:Version bump $f <major|minor|patch> \"<reason>\"" >&2
    fail=1
    continue
  fi

  want=$(git show :"$f" | hash_stdin)
  if ! git show :"$meta" | grep -qF "$want"; then
    echo "RWANG gate: sidecar hash for '$f' does not match the staged content." >&2
    echo "            Re-run: RWANG:Version bump $f <major|minor|patch> \"<reason>\"" >&2
    fail=1
  fi
done

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "Commit rejected by the RWANG write gate (RWANG-VERSION.md §7)." >&2
  echo "Do NOT use --no-verify — the next RWANG:Version audit will catch and report it." >&2
fi
exit $fail
